[21.985, "o", "\r\n  \u001b[32m\u001b[1mBashlings\u001b[22m\u001b[39m  ¬∑  umumiy progress\r\n\r\n  [\u001b[32m\u001b[39m\u001b[2m‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ\u001b[22m]   0%  \u001b[32m\u001b[1m0\u001b[22m\u001b[39m/101\r\n\r\n  \u001b[2m¬∑\u001b[22m  part1/01-introduction       [\u001b[32m\u001b[39m\u001b[2m‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ\u001b[22m]   0%  0/5\r\n  \u001b[2m¬∑\u001b[22m  part1/02-navigation         [\u001b[32m\u001b[39m\u001b[2m‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ\u001b[22m]   0%  0/8\r\n  \u001b[2m¬∑\u001b[22m  part1/03-pipes-redirection  [\u001b[32m\u001b[39m\u001b[2m‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ\u001b[22m]   0%  0/8\r\n  \u001b[2m¬∑\u001b[22m  part1/04-text-processing    [\u001b[32m\u001b[39m\u001b[2m‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ\u001b[22m]   0%  0/5\r\n  \u001b[2m¬∑\u001b[22m  part1/05-basic-scripting    [\u001b[32m\u001b[39m\u001b[2m‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ\u001b[22m]   0%  0/6\r\n  \u001b[2m¬∑\u001b[22m  part2/01-functions          [\u001b[32m\u001b[39m\u001b[2m‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ\u001b[22m]   0%  0/6\r\n  \u001b[2m¬∑\u001b[22m  part2/02-arrays             [\u001b[32m\u001b[39m\u001b[2m‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ\u001b[22m]   0%  0/6\r\n  \u001b[2m¬∑\u001b[22m  part2/03-sed-awk            [\u001b[32m\u001b[39m\u001b[2m‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ\u001b[22m]   0%  0/6\r\n  \u001b[2m¬∑\u001b[22m  part2/04-traps-signals      [\u001b[32m\u001b[39m\u001b[2m‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ\u001b[22m]   0%  0/5\r\n  \u001b[2m¬∑\u001b[22m  part2/05-robust-scripting   [\u001b[32m\u001b[39m\u001b[2m‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ\u001b[22m]   0%  0/5\r\n  \u001b[2m¬∑\u001b[22m  part3/01-network            [\u001b[32m\u001b[39m\u001b[2m‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ\u001b[22m]   0%  0/7\r\n  \u001b[2m¬∑\u001b[22m  part3/02-ssh                [